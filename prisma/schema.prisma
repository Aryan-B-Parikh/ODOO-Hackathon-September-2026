datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// ENUMS
// ==========================================

enum UserStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum EmployeeStatus {
  ACTIVE
  LEAVE
  TERMINATED
}

enum DepartmentStatus {
  ACTIVE
  INACTIVE
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum Condition {
  NEW
  EXCELLENT
  GOOD
  FAIR
  POOR
  DAMAGED
}

enum AllocationStatus {
  ACTIVE
  RETURNED
  TRANSFERRED
}

enum TransferStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  REJECTED
  TECHNICIAN_ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum AuditCycleStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum AuditAssetStatus {
  PENDING
  VERIFIED
  MISSING
  DAMAGED
}

enum DiscrepancyStatus {
  OPEN
  RESOLVED
  IGNORED
}

enum NotificationType {
  SYSTEM
  ALLOCATION
  MAINTENANCE
  BOOKING
  TRANSFER
  AUDIT
  ALERT
}

enum Severity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum DepreciationMethod {
  STRAIGHT_LINE
  DECLINING_BALANCE
  UNITS_OF_PRODUCTION
}

// ==========================================
// MODELS
// ==========================================

model Organization {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  
  // Auditable & Soft Delete
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  isDeleted Boolean  @default(false)

  // Back-references for multitenancy
  users           User[]
  employees       Employee[]
  departments     Department[]
  categories      AssetCategory[]
  assets          Asset[]
  vendors         Vendor[]
  auditCycles     AuditCycle[]

  @@index([isDeleted])
}

model User {
  id                  String       @id @default(uuid())
  email               String       @unique
  passwordHash        String
  emailVerified       Boolean      @default(false)
  status              UserStatus   @default(ACTIVE)
  
  // Multitenancy
  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  // Relations
  employee            Employee?
  sessions            Session[]
  refreshTokens       RefreshToken[]
  emailVerifications  EmailVerification[]
  passwordResets      PasswordReset[]
  userRoles           UserRole[]
  activityLogs        ActivityLog[]

  // Auditable & Soft Delete
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  deletedAt           DateTime?
  isDeleted           Boolean      @default(false)

  @@index([organizationId])
  @@index([status])
  @@index([isDeleted])
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique // e.g. "ADMIN", "ASSET_MANAGER", "DEPARTMENT_HEAD", "EMPLOYEE"
  description String?
  
  permissions RolePermission[]
  userRoles   UserRole[]

  // Auditable & Soft Delete
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  isDeleted   Boolean  @default(false)

  @@index([isDeleted])
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique // e.g. "asset.create", "asset.allocate"
  description String?

  roles       RolePermission[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([roleId, permissionId])
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model Session {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  ipAddress String
  userAgent String
  deviceId  String?
  
  expiresAt DateTime
  revokedAt DateTime?
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, expiresAt])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  token     String    @unique
  expiresAt DateTime
  revokedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, expiresAt])
}

model EmailVerification {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  token      String    @unique
  expiresAt  DateTime
  verifiedAt DateTime?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model PasswordReset {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, expiresAt])
}

model Employee {
  id           String         @id @default(uuid())
  name         String
  email        String         @unique
  phone        String?
  status       EmployeeStatus @default(ACTIVE)
  
  // Link to User authentication profile
  userId       String?        @unique
  user         User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Multitenancy
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  // Department Relationship
  departmentId String?
  department   Department?    @relation("EmployeeDepartment", fields: [departmentId], references: [id], onDelete: Restrict)

  // Self-referencing manager mapping
  managerId    String?
  manager      Employee?      @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)
  subordinates Employee[]     @relation("EmployeeManager")

  // One-to-one mapping for headed department
  headedDepartment Department? @relation("DepartmentHead")

  // Allocations
  allocations        AssetAllocation[] @relation("EmployeeAllocations")
  createdAllocations AssetAllocation[] @relation("AllocationCreator")

  // Transfer Workflows
  raisedTransfers   AssetTransferRequest[] @relation("TransferRequestor")
  targetTransfers   AssetTransferRequest[] @relation("TransferTargetEmployee")
  actionedTransfers AssetTransferRequest[] @relation("TransferActioner")

  // Bookings
  bookings ResourceBooking[]

  // Maintenance Workflows
  raisedMaintenance   MaintenanceRequest[] @relation("MaintenanceRequestor")
  actionedMaintenance MaintenanceRequest[] @relation("MaintenanceActioner")
  assignedMaintenance MaintenanceRequest[] @relation("MaintenanceTechnician")

  // Auditing
  auditedCycles         AuditAuditor[]
  createdAuditCycles    AuditCycle[]       @relation("AuditCreator")
  closedAuditCycles     AuditCycle[]       @relation("AuditCloser")
  verifiedAuditResults  AuditAssetResult[]
  resolvedDiscrepancies AuditDiscrepancy[]

  // Messages
  notifications Notification[]

  // Auditable & Soft Delete
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  isDeleted Boolean  @default(false)

  @@index([organizationId])
  @@index([status])
  @@index([isDeleted])
}

model Department {
  id             String           @id @default(uuid())
  name           String
  code           String           @unique
  status         DepartmentStatus @default(ACTIVE)
  path           String?          // Materialized path for tree traversal e.g. "root/eng/dev"

  // Multitenancy
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  // One-to-One Head of Department
  headId         String?          @unique
  head           Employee?        @relation("DepartmentHead", fields: [headId], references: [id], onDelete: Restrict)

  // Self-Referencing Parent-Child Hierarchy
  parentId       String?
  parent         Department?      @relation("DepartmentHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children       Department[]     @relation("DepartmentHierarchy")

  // Back-references
  employees        Employee[]             @relation("EmployeeDepartment")
  assets           Asset[]                @relation("AssetDepartment")
  allocations      AssetAllocation[]
  transferRequests AssetTransferRequest[] @relation("TargetDepartment")
  bookings         ResourceBooking[]
  auditCycles      AuditCycle[]

  // Auditable & Soft Delete
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  isDeleted Boolean  @default(false)

  @@index([organizationId])
  @@index([parentId])
  @@index([isDeleted])
}

model AssetCategory {
  id                 String       @id @default(uuid())
  name               String       @unique
  description        String?
  customFieldSchema  Json?        // Meta-schema defining category-specific attributes

  // Multitenancy
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  assets             Asset[]

  // Auditable & Soft Delete
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  isDeleted Boolean  @default(false)

  @@index([organizationId])
  @@index([isDeleted])
}

model Asset {
  id              String      @id @default(uuid())
  name            String
  categoryId      String
  category        AssetCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  
  assetTag        String      @unique // e.g. AF-0001
  serialNumber    String?     @unique
  barcode         String?     @unique
  qrCode          String?     @unique
  
  acquisitionDate DateTime?
  acquisitionCost Decimal?    @db.Decimal(12, 2)
  condition       Condition   @default(NEW)
  location        String
  sharedBookable  Boolean     @default(false)
  status          AssetStatus @default(AVAILABLE)

  // Multitenancy
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  // Prevent double-allocation using unique current allocation
  currentAllocationId String?          @unique
  currentAllocation   AssetAllocation? @relation("CurrentAllocation", fields: [currentAllocationId], references: [id], onDelete: SetNull)

  // Departmental Ownership
  departmentId String?
  department   Department? @relation("AssetDepartment", fields: [departmentId], references: [id], onDelete: Restrict)

  // Supplier details
  vendorId     String?
  vendor       Vendor?     @relation(fields: [vendorId], references: [id], onDelete: Restrict)

  // Normalized relations instead of flat lists
  images       AssetImage[]
  documents    AssetDocument[]
  warranties   AssetWarranty[]
  insurances   AssetInsurance[]
  depreciations AssetDepreciation[]

  // Operational records (Retention history)
  allocations      AssetAllocation[]      @relation("AssetHistory")
  transfers        AssetTransferRequest[]
  bookings         ResourceBooking[]
  maintenances     MaintenanceRequest[]
  auditResults     AuditAssetResult[]
  discrepancies    AuditDiscrepancy[]

  // Auditable & Soft Delete
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  isDeleted Boolean  @default(false)

  @@index([organizationId])
  @@index([status])
  @@index([categoryId])
  @@index([departmentId])
  @@index([location])
  @@index([isDeleted])
  @@index([qrCode])
  @@index([barcode])
  @@index([departmentId, status])
}

model Vendor {
  id             String       @id @default(uuid())
  name           String
  contactEmail   String?
  contactPhone   String?
  address        String?

  // Multitenancy
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  assets         Asset[]
  warranties     AssetWarranty[]

  // Auditable & Soft Delete
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  isDeleted Boolean  @default(false)

  @@index([organizationId])
  @@index([isDeleted])
}

model AssetImage {
  id         String   @id @default(uuid())
  assetId    String
  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  url        String
  isPrimary  Boolean  @default(false)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AssetDocument {
  id         String   @id @default(uuid())
  assetId    String
  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  name       String
  url        String
  fileType   String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AssetWarranty {
  id                String    @id @default(uuid())
  assetId           String
  asset             Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  vendorId          String?
  vendor            Vendor?   @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  policyNumber      String?
  warrantyStartDate DateTime
  warrantyEndDate   DateTime
  coverageDetails   String?

  // Auditable & Soft Delete
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  isDeleted Boolean  @default(false)

  @@index([isDeleted])
}

model AssetInsurance {
  id             String    @id @default(uuid())
  assetId        String
  asset          Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  providerName   String
  policyNumber   String
  coverageAmount Decimal   @db.Decimal(12, 2)
  startDate      DateTime
  endDate        DateTime

  // Auditable & Soft Delete
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  isDeleted Boolean  @default(false)

  @@index([isDeleted])
}

model AssetDepreciation {
  id                    String             @id @default(uuid())
  assetId               String
  asset                 Asset              @relation(fields: [assetId], references: [id], onDelete: Cascade)
  method                DepreciationMethod @default(STRAIGHT_LINE)
  depreciationStartDate DateTime
  salvageValue          Decimal            @db.Decimal(12, 2)
  usefulLifeMonths      Int
  accumulatedDepreciation Decimal          @db.Decimal(12, 2) @default(0.0)
  currentBookValue      Decimal            @db.Decimal(12, 2)

  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
}

model AssetAllocation {
  id         String @id @default(uuid())
  assetId    String
  asset      Asset  @relation("AssetHistory", fields: [assetId], references: [id], onDelete: Cascade)

  // Can be assigned to Employee OR Department
  employeeId   String?
  employee     Employee?   @relation("EmployeeAllocations", fields: [employeeId], references: [id], onDelete: Restrict)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: Restrict)

  allocatedById String
  allocatedBy   Employee @relation("AllocationCreator", fields: [allocatedById], references: [id], onDelete: Restrict)

  allocatedAt        DateTime         @default(now())
  expectedReturnDate DateTime?
  actualReturnDate   DateTime?
  status             AllocationStatus @default(ACTIVE)

  checkoutCondition Condition
  checkinCondition  Condition?
  checkoutNotes     String?
  checkinNotes      String?

  // Current allocation check
  currentForAsset Asset? @relation("CurrentAllocation")

  // Auditable & Soft Delete
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  isDeleted Boolean  @default(false)

  @@index([employeeId, status])
  @@index([departmentId, status])
  @@index([status])
  @@index([isDeleted])
}

model AssetTransferRequest {
  id      String @id @default(uuid())
  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  requestorId String
  requestor   Employee @relation("TransferRequestor", fields: [requestorId], references: [id], onDelete: Restrict)

  // Destination targets
  targetEmployeeId   String?
  targetEmployee     Employee?   @relation("TransferTargetEmployee", fields: [targetEmployeeId], references: [id], onDelete: Restrict)
  targetDepartmentId String?
  targetDepartment   Department? @relation("TargetDepartment", fields: [targetDepartmentId], references: [id], onDelete: Restrict)

  status TransferStatus @default(PENDING)

  actionedById String?
  actionedBy   Employee? @relation("TransferActioner", fields: [actionedById], references: [id], onDelete: Restrict)
  actionedAt   DateTime?

  requestNotes   String?
  actionNotes    String?
  rejectionReason String?

  // Auditable & Soft Delete
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  isDeleted Boolean  @default(false)

  @@index([status])
  @@index([isDeleted])
}

model ResourceBooking {
  id      String @id @default(uuid())
  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  bookedById String
  bookedBy   Employee @relation(fields: [bookedById], references: [id], onDelete: Restrict)

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: Restrict)

  startTime DateTime
  endTime   DateTime
  status    BookingStatus @default(UPCOMING)
  notes     String?

  // Auditable & Soft Delete
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  isDeleted Boolean  @default(false)

  // Multi-column index for overlap searches and scaling query optimization
  @@index([assetId, startTime, endTime])
  @@index([assetId, status, startTime])
  @@index([status])
  @@index([isDeleted])
}

model MaintenanceRequest {
  id      String @id @default(uuid())
  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  raisedById String
  raisedBy   Employee @relation("MaintenanceRequestor", fields: [raisedById], references: [id], onDelete: Restrict)

  description String
  priority    Priority          @default(MEDIUM)
  status      MaintenanceStatus @default(PENDING)
  photoUrl    String?

  approvedById String?
  approvedBy   Employee? @relation("MaintenanceActioner", fields: [approvedById], references: [id], onDelete: Restrict)
  approvedAt   DateTime?

  technicianId       String?
  technician         Employee? @relation("MaintenanceTechnician", fields: [technicianId], references: [id], onDelete: Restrict)
  externalTechnician String?

  estimatedCost      Decimal?  @db.Decimal(12, 2)
  actualCost         Decimal?  @db.Decimal(12, 2)
  resolutionNotes    String?
  resolvedAt         DateTime?

  // Auditable & Soft Delete
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  isDeleted Boolean  @default(false)

  @@index([status])
  @@index([assetId, status])
  @@index([isDeleted])
}

model AuditCycle {
  id                String      @id @default(uuid())
  name              String
  scopeDepartmentId String?
  scopeDepartment   Department? @relation(fields: [scopeDepartmentId], references: [id], onDelete: Restrict)
  scopeLocation     String?

  startDate DateTime
  endDate   DateTime
  status    AuditCycleStatus @default(PLANNED)

  // Multitenancy
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  createdById String
  createdBy   Employee @relation("AuditCreator", fields: [createdById], references: [id], onDelete: Restrict)

  closedById String?
  closedBy   Employee? @relation("AuditCloser", fields: [closedById], references: [id], onDelete: Restrict)
  closedAt   DateTime?

  // Relations
  auditors      AuditAuditor[]
  results       AuditAssetResult[]
  discrepancies AuditDiscrepancy[]

  // Auditable & Soft Delete
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  isDeleted Boolean  @default(false)

  @@index([organizationId])
  @@index([status])
  @@index([isDeleted])
}

model AuditAuditor {
  id           String     @id @default(uuid())
  auditCycleId String
  auditCycle   AuditCycle @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)
  employeeId   String
  employee     Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  assignedAt   DateTime   @default(now())

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([auditCycleId, employeeId])
}

model AuditAssetResult {
  id           String     @id @default(uuid())
  auditCycleId String
  auditCycle   AuditCycle @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)
  assetId      String
  asset        Asset      @relation(fields: [assetId], references: [id], onDelete: Cascade)

  auditorId    String
  auditor      Employee   @relation(fields: [auditorId], references: [id], onDelete: Restrict)

  status       AuditAssetStatus @default(PENDING)
  notes        String?
  verifiedAt   DateTime?

  discrepancy  AuditDiscrepancy?

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([auditCycleId, assetId])
}

model AuditDiscrepancy {
  id                 String     @id @default(uuid())
  auditCycleId       String
  auditCycle         AuditCycle @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)
  assetId            String
  asset              Asset      @relation(fields: [assetId], references: [id], onDelete: Cascade)
  
  auditAssetResultId String     @unique
  auditAssetResult   AuditAssetResult @relation(fields: [auditAssetResultId], references: [id], onDelete: Cascade)

  reportedStatus     AuditAssetStatus // Only MISSING or DAMAGED
  resolutionStatus   DiscrepancyStatus @default(OPEN)

  resolvedById       String?
  resolvedBy         Employee?  @relation(fields: [resolvedById], references: [id], onDelete: Restrict)
  resolvedAt         DateTime?
  resolutionNotes    String?

  // Auditable & Soft Delete
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  isDeleted Boolean  @default(false)

  @@index([resolutionStatus])
  @@index([isDeleted])
}

model Notification {
  id          String           @id @default(uuid())
  recipientId String
  recipient   Employee         @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  
  title       String
  message     String
  type        NotificationType
  isRead      Boolean          @default(false)
  readAt      DateTime?
  referenceId String?          // Holds target object uuid

  // Auditable & Soft Delete
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([recipientId, isRead])
  @@index([recipientId, createdAt])
}

model ActivityLog {
  id           String    @id @default(uuid())
  userId       String?
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  action       String    // e.g. "USER_LOGIN", "ASSET_ALLOCATE"
  entityType   String    // e.g. "Asset", "AuditCycle"
  entityId     String?
  oldValue     Json?     // Stores previous state for audit compliance
  newValue     Json?     // Stores updated state values
  severity     Severity  @default(INFO)

  ipAddress    String?
  userAgent    String?
  deviceId     String?

  success      Boolean   @default(true)
  errorMessage String?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId, createdAt])
  @@index([entityType, entityId])
}