datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// ENUMS
// ==========================================

enum UserStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum EmployeeStatus {
  ACTIVE
  LEAVE
  TERMINATED
}

enum DepartmentStatus {
  ACTIVE
  INACTIVE
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum Condition {
  NEW
  EXCELLENT
  GOOD
  FAIR
  POOR
  DAMAGED
}

enum AllocationStatus {
  ACTIVE
  RETURNED
  TRANSFERRED
}

enum TransferStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  REJECTED
  TECHNICIAN_ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum AuditCycleStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum AuditAssetStatus {
  PENDING
  VERIFIED
  MISSING
  DAMAGED
}

enum DiscrepancyStatus {
  OPEN
  RESOLVED
  IGNORED
}

enum NotificationType {
  SYSTEM
  ALLOCATION
  MAINTENANCE
  BOOKING
  TRANSFER
  AUDIT
  ALERT
}

enum Severity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum DepreciationMethod {
  STRAIGHT_LINE
  DECLINING_BALANCE
  UNITS_OF_PRODUCTION
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
}

// ==========================================
// MODELS
// ==========================================

model Organization {
  id                      String                    @id @default(uuid())
  name                    String
  code                    String                    @unique
  
  // Auditable & Soft Delete
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  deletedAt               DateTime?
  isDeleted               Boolean                   @default(false)

  // Back-references for multitenancy
  users                   User[]
  employees               Employee[]
  departments             Department[]
  categories              AssetCategory[]
  assets                  Asset[]
  vendors                 Vendor[]
  auditCycles             AuditCycle[]
  locations               Location[]
  allocations             AssetAllocation[]
  bookings                ResourceBooking[]
  maintenances            MaintenanceRequest[]
  transfers               AssetTransferRequest[]
  auditResults            AuditAssetResult[]
  discrepancies           AuditDiscrepancy[]
  histories               AssetHistory[]
  emailQueues             EmailQueue[]
  notificationPreferences NotificationPreference[]
  bookingReminders        ResourceBookingReminder[]
  maintenanceWorkLogs     MaintenanceWorkLog[]
  maintenanceAttachments  MaintenanceAttachment[]
  auditResultHistories    AuditResultHistory[]
  notifications           Notification[]

  @@index([isDeleted])
}

model User {
  id                      String                    @id @default(uuid())
  email                   String                    @unique
  passwordHash            String
  emailVerified           Boolean                   @default(false)
  status                  UserStatus                @default(ACTIVE)
  
  // Brute-force protection & Lockout Metrics
  lastLoginAt             DateTime?
  loginAttempts           Int                       @default(0)
  lockoutUntil            DateTime?

  // Multitenancy
  organizationId          String
  organization            Organization              @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  // Employee-Only Signup enforcement (Strict 1:1 validation)
  employeeId              String
  employee                Employee                  @relation(fields: [employeeId, email], references: [id, email], onDelete: Cascade)

  // Relations
  sessions                Session[]
  refreshTokens           RefreshToken[]
  emailVerifications      EmailVerification[]
  passwordResets          PasswordReset[]
  userRoles               UserRole[]
  activityLogs            ActivityLog[]
  notificationPreferences NotificationPreference[]

  // Audit Trails Back-references (Creator, Updater, Deleter)
  createdAssets           Asset[]                   @relation("AssetCreator")
  updatedAssets           Asset[]                   @relation("AssetUpdater")
  deletedAssets           Asset[]                   @relation("AssetDeleter")

  createdCategories       AssetCategory[]           @relation("CategoryCreator")
  updatedCategories       AssetCategory[]           @relation("CategoryUpdater")
  deletedCategories       AssetCategory[]           @relation("CategoryDeleter")

  createdDepartments      Department[]              @relation("DepartmentCreator")
  updatedDepartments      Department[]              @relation("DepartmentUpdater")
  deletedDepartments      Department[]              @relation("DepartmentDeleter")

  createdMaintenances     MaintenanceRequest[]      @relation("MaintenanceCreator")
  updatedMaintenances     MaintenanceRequest[]      @relation("MaintenanceUpdater")
  deletedMaintenances     MaintenanceRequest[]      @relation("MaintenanceDeleter")

  createdAudits           AuditCycle[]              @relation("AuditCycleCreator")
  updatedAudits           AuditCycle[]              @relation("AuditCycleUpdater")
  deletedAudits           AuditCycle[]              @relation("AuditCycleDeleter")

  assetHistories          AssetHistory[]            @relation("UserAssetHistories")
  auditResultHistories    AuditResultHistory[]      @relation("UserAuditResultHistories")

  // Auditable & Soft Delete
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  deletedAt               DateTime?
  isDeleted               Boolean                   @default(false)

  @@index([organizationId])
  @@index([status])
  @@index([isDeleted])
  @@unique([employeeId, email])
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  
  permissions RolePermission[]
  userRoles   UserRole[]

  // Auditable & Soft Delete
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  isDeleted   Boolean  @default(false)

  @@index([isDeleted])
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?

  roles       RolePermission[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([roleId, permissionId])
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model Session {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  ipAddress String
  userAgent String
  deviceId  String?
  
  expiresAt DateTime
  revokedAt DateTime?
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, expiresAt])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  token     String    @unique
  expiresAt DateTime
  revokedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, expiresAt])
}

model EmailVerification {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  token      String    @unique
  expiresAt  DateTime
  verifiedAt DateTime?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model PasswordReset {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, expiresAt])
}

model Employee {
  id             String         @id @default(uuid())
  name           String
  email          String         @unique
  phone          String?
  status         EmployeeStatus @default(ACTIVE)
  
  // Back-relation to User configuration
  user           User?

  // Multitenancy
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  // Department Relationship
  departmentId   String?
  department     Department?    @relation("EmployeeDepartment", fields: [departmentId], references: [id], onDelete: Restrict)

  // Self-referencing manager mapping
  managerId      String?
  manager        Employee?      @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)
  subordinates   Employee[]     @relation("EmployeeManager")

  // One-to-one mapping for headed department
  headedDepartment Department? @relation("DepartmentHead")

  // Allocations
  allocations        AssetAllocation[] @relation("EmployeeAllocations")
  createdAllocations AssetAllocation[] @relation("AllocationCreator")

  // Transfer Workflows
  raisedTransfers   AssetTransferRequest[] @relation("TransferRequestor")
  targetTransfers   AssetTransferRequest[] @relation("TransferTargetEmployee")
  actionedTransfers AssetTransferRequest[] @relation("TransferActioner")

  // Bookings
  bookings ResourceBooking[]

  // Maintenance Workflows
  raisedMaintenance   MaintenanceRequest[] @relation("MaintenanceRequestor")
  actionedMaintenance MaintenanceRequest[] @relation("MaintenanceActioner")
  assignedMaintenance MaintenanceRequest[] @relation("MaintenanceTechnician")
  maintenanceWorkLogs MaintenanceWorkLog[]

  // Auditing
  auditedCycles         AuditAuditor[]
  createdAuditCycles    AuditCycle[]       @relation("AuditCreator")
  closedAuditCycles     AuditCycle[]       @relation("AuditCloser")
  verifiedAuditResults  AuditAssetResult[]
  resolvedDiscrepancies AuditDiscrepancy[]

  // Messages
  notifications Notification[]

  // Auditable & Soft Delete
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  isDeleted Boolean  @default(false)

  @@index([organizationId])
  @@index([status])
  @@index([isDeleted])
  @@unique([id, email])
}

model Department {
  id             String           @id @default(uuid())
  name           String
  code           String           @unique
  status         DepartmentStatus @default(ACTIVE)
  path           String?          // Materialized path for tree traversal

  // Multitenancy
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  // One-to-One Head of Department
  headId         String?          @unique
  head           Employee?        @relation("DepartmentHead", fields: [headId], references: [id], onDelete: Restrict)

  // Self-Referencing Parent-Child Hierarchy
  parentId       String?
  parent         Department?      @relation("DepartmentHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children       Department[]     @relation("DepartmentHierarchy")

  // Back-references
  employees        Employee[]             @relation("EmployeeDepartment")
  assets           Asset[]                @relation("AssetDepartment")
  allocations      AssetAllocation[]
  transferRequests AssetTransferRequest[] @relation("TargetDepartment")
  bookings         ResourceBooking[]
  auditCycles      AuditCycle[]
  assetHistories   AssetHistory[]

  // Audit support
  createdByUserId String?
  createdByUser   User?           @relation("DepartmentCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedByUserId String?
  updatedByUser   User?           @relation("DepartmentUpdater", fields: [updatedByUserId], references: [id], onDelete: Restrict)
  deletedByUserId String?
  deletedByUser   User?           @relation("DepartmentDeleter", fields: [deletedByUserId], references: [id], onDelete: Restrict)

  // Auditable & Soft Delete
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  isDeleted Boolean  @default(false)

  @@index([organizationId])
  @@index([parentId])
  @@index([isDeleted])
}

model AssetCategory {
  id                 String       @id @default(uuid())
  name               String       @unique
  description        String?
  customFieldSchema  Json?        // Meta-schema defining category-specific attributes

  // Multitenancy
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  assets             Asset[]

  // Audit support
  createdByUserId    String?
  createdByUser      User?        @relation("CategoryCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedByUserId    String?
  updatedByUser      User?        @relation("CategoryUpdater", fields: [updatedByUserId], references: [id], onDelete: Restrict)
  deletedByUserId    String?
  deletedByUser      User?        @relation("CategoryDeleter", fields: [deletedByUserId], references: [id], onDelete: Restrict)

  // Auditable & Soft Delete
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  isDeleted Boolean  @default(false)

  @@index([organizationId])
  @@index([isDeleted])
}

model Location {
  id             String         @id @default(uuid())
  name           String
  code           String         @unique
  parentId       String?
  parent         Location?      @relation("LocationHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children       Location[]     @relation("LocationHierarchy")
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  assets         Asset[]
  assetHistories AssetHistory[]

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?
  isDeleted      Boolean        @default(false)

  @@index([organizationId])
  @@index([parentId])
}

model Asset {
  id                     String      @id @default(uuid())
  name                   String
  categoryId             String
  category               AssetCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  
  assetTag               String      @unique // e.g. AF-0001
  serialNumber           String?     @unique
  barcode                String?     @unique
  qrCode                 String?     @unique
  
  acquisitionDate        DateTime?
  acquisitionCost        Decimal?    @db.Decimal(12, 2)
  condition              Condition   @default(NEW)
  expectedLifetimeMonths Int?        // Estimated useful lifetime in months
  expectedRetirementDate DateTime?   // Calculated retirement forecast
  customFieldValues      Json?       // Stores actual dynamic custom field parameters

  // Hierarchical location relationship
  locationId             String
  location               Location    @relation(fields: [locationId], references: [id], onDelete: Restrict)

  sharedBookable         Boolean     @default(false)
  status                 AssetStatus @default(AVAILABLE)

  // Multitenancy
  organizationId         String
  organization           Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  // Departmental Ownership
  departmentId           String?
  department             Department? @relation("AssetDepartment", fields: [departmentId], references: [id], onDelete: Restrict)

  // Supplier details
  vendorId               String?
  vendor                 Vendor?     @relation(fields: [vendorId], references: [id], onDelete: Restrict)

  // Normalized media, warranties, insurances
  images                 AssetImage[]
  documents              AssetDocument[]
  warranties             AssetWarranty[]
  insurances             AssetInsurance[]
  depreciations          AssetDepreciation[]

  // Transaction history - onDelete: Restrict (Protects audit trail logs from deletion)
  allocations            AssetAllocation[]      @relation("AssetHistory")
  transfers              AssetTransferRequest[]
  bookings               ResourceBooking[]
  maintenances           MaintenanceRequest[]
  auditResults           AuditAssetResult[]
  discrepancies          AuditDiscrepancy[]
  histories              AssetHistory[]

  // Audit support
  createdByUserId        String?
  createdByUser          User?        @relation("AssetCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedByUserId        String?
  updatedByUser          User?        @relation("AssetUpdater", fields: [updatedByUserId], references: [id], onDelete: Restrict)
  deletedByUserId        String?
  deletedByUser          User?        @relation("AssetDeleter", fields: [deletedByUserId], references: [id], onDelete: Restrict)

  // Auditable & Soft Delete
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  isDeleted Boolean  @default(false)

  @@index([organizationId])
  @@index([status])
  @@index([categoryId])
  @@index([departmentId])
  @@index([isDeleted])
  @@index([qrCode])
  @@index([barcode])
  @@index([departmentId, status])
}

model Vendor {
  id             String       @id @default(uuid())
  name           String
  contactEmail   String?
  contactPhone   String?
  address        String?

  // Multitenancy
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  assets         Asset[]
  warranties     AssetWarranty[]

  // Auditable & Soft Delete
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  isDeleted Boolean  @default(false)

  @@index([organizationId])
  @@index([isDeleted])
}

model AssetImage {
  id         String   @id @default(uuid())
  assetId    String
  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  url        String
  isPrimary  Boolean  @default(false)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AssetDocument {
  id         String   @id @default(uuid())
  assetId    String
  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  name       String
  url        String
  fileType   String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AssetWarranty {
  id                String    @id @default(uuid())
  assetId           String
  asset             Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  vendorId          String?
  vendor            Vendor?   @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  policyNumber      String?
  warrantyStartDate DateTime
  warrantyEndDate   DateTime
  coverageDetails   String?

  // Auditable & Soft Delete
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  isDeleted Boolean  @default(false)

  @@index([isDeleted])
}

model AssetInsurance {
  id             String    @id @default(uuid())
  assetId        String
  asset          Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  providerName   String
  policyNumber   String
  coverageAmount Decimal   @db.Decimal(12, 2)
  startDate      DateTime
  endDate        DateTime

  // Auditable & Soft Delete
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  isDeleted Boolean  @default(false)

  @@index([isDeleted])
}

model AssetDepreciation {
  id                    String             @id @default(uuid())
  assetId               String
  asset                 Asset              @relation(fields: [assetId], references: [id], onDelete: Cascade)
  method                DepreciationMethod @default(STRAIGHT_LINE)
  depreciationStartDate DateTime
  salvageValue          Decimal            @db.Decimal(12, 2)
  usefulLifeMonths      Int
  accumulatedDepreciation Decimal          @db.Decimal(12, 2) @default(0.0)
  currentBookValue      Decimal            @db.Decimal(12, 2)

  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
}

model AssetAllocation {
  id                 String           @id @default(uuid())
  assetId            String
  asset              Asset            @relation("AssetHistory", fields: [assetId], references: [id], onDelete: Restrict) // Audit Integrity protected

  // Can be assigned to Employee OR Department
  employeeId         String?
  employee           Employee?        @relation("EmployeeAllocations", fields: [employeeId], references: [id], onDelete: Restrict)
  departmentId       String?
  department         Department?      @relation(fields: [departmentId], references: [id], onDelete: Restrict)

  allocatedById      String
  allocatedBy        Employee         @relation("AllocationCreator", fields: [allocatedById], references: [id], onDelete: Restrict)

  allocatedAt        DateTime         @default(now())
  expectedReturnDate DateTime?
  actualReturnDate   DateTime?
  status             AllocationStatus @default(ACTIVE)

  checkoutCondition  Condition
  checkinCondition   Condition?
  checkoutNotes      String?
  checkinNotes       String?

  // Multitenancy denormalization
  organizationId     String
  organization       Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  // Auditable & Soft Delete
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  deletedAt          DateTime?
  isDeleted          Boolean          @default(false)

  @@index([employeeId, status])
  @@index([departmentId, status])
  @@index([status])
  @@index([isDeleted])
  @@index([organizationId])
  @@index([expectedReturnDate, status]) // Overdue check index
}

model AssetTransferRequest {
  id                 String         @id @default(uuid())
  assetId            String
  asset              Asset          @relation(fields: [assetId], references: [id], onDelete: Restrict) // Audit Integrity protected

  requestorId        String
  requestor          Employee       @relation("TransferRequestor", fields: [requestorId], references: [id], onDelete: Restrict)

  // Destination targets
  targetEmployeeId   String?
  targetEmployee     Employee?      @relation("TransferTargetEmployee", fields: [targetEmployeeId], references: [id], onDelete: Restrict)
  targetDepartmentId String?
  targetDepartment   Department?    @relation("TargetDepartment", fields: [targetDepartmentId], references: [id], onDelete: Restrict)

  status             TransferStatus @default(PENDING)

  actionedById       String?
  actionedBy         Employee?      @relation("TransferActioner", fields: [actionedById], references: [id], onDelete: Restrict)
  actionedAt         DateTime?

  requestNotes       String?
  actionNotes        String?
  rejectionReason    String?

  // Multitenancy denormalization
  organizationId     String
  organization       Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  // Auditable & Soft Delete
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  deletedAt          DateTime?
  isDeleted          Boolean        @default(false)

  @@index([status])
  @@index([isDeleted])
  @@index([organizationId])
}

model ResourceBooking {
  id             String          @id @default(uuid())
  assetId        String
  asset          Asset           @relation(fields: [assetId], references: [id], onDelete: Restrict) // Audit Integrity protected

  bookedById     String
  bookedBy       Employee        @relation(fields: [bookedById], references: [id], onDelete: Restrict)

  departmentId   String?
  department     Department?     @relation(fields: [departmentId], references: [id], onDelete: Restrict)

  startTime      DateTime
  endTime        DateTime
  status         BookingStatus   @default(UPCOMING)
  notes          String?

  // Recurrence rule configurations
  recurrenceRule String?         // RFC 5545 RRULE string
  seriesId       String?         // Links occurrences to a parent series
  reminders      ResourceBookingReminder[]

  // Multitenancy denormalization
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  // Auditable & Soft Delete
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?
  isDeleted      Boolean         @default(false)

  // Multi-column index for overlap searches and scaling query optimization
  @@index([assetId, startTime, endTime])
  @@index([assetId, status, startTime])
  @@index([status])
  @@index([isDeleted])
  @@index([organizationId])
  @@index([seriesId])
  @@index([bookedById])
}

model MaintenanceRequest {
  id                 String             @id @default(uuid())
  assetId            String
  asset              Asset              @relation(fields: [assetId], references: [id], onDelete: Restrict) // Audit Integrity protected

  raisedById         String
  raisedBy           Employee           @relation("MaintenanceRequestor", fields: [raisedById], references: [id], onDelete: Restrict)

  description        String
  priority           Priority           @default(MEDIUM)
  status             MaintenanceStatus  @default(PENDING)

  approvedById       String?
  approvedBy         Employee?          @relation("MaintenanceActioner", fields: [approvedById], references: [id], onDelete: Restrict)
  approvedAt         DateTime?

  technicianId       String?
  technician         Employee?          @relation("MaintenanceTechnician", fields: [technicianId], references: [id], onDelete: Restrict)
  externalTechnician String?

  estimatedCost      Decimal?           @db.Decimal(12, 2)
  actualCost         Decimal?           @db.Decimal(12, 2)
  resolutionNotes    String?
  resolvedAt         DateTime?

  // Logs & attachments
  attachments        MaintenanceAttachment[]
  workLogs           MaintenanceWorkLog[]

  // Multitenancy denormalization
  organizationId     String
  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  // Audit support
  createdByUserId    String?
  createdByUser      User?              @relation("MaintenanceCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedByUserId    String?
  updatedByUser      User?              @relation("MaintenanceUpdater", fields: [updatedByUserId], references: [id], onDelete: Restrict)
  deletedByUserId    String?
  deletedByUser      User?              @relation("MaintenanceDeleter", fields: [deletedByUserId], references: [id], onDelete: Restrict)

  // Auditable & Soft Delete
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  isDeleted Boolean  @default(false)

  @@index([status])
  @@index([assetId, status])
  @@index([isDeleted])
  @@index([organizationId])
  @@index([technicianId, status])
  @@index([raisedById])
}

model AuditCycle {
  id                String      @id @default(uuid())
  name              String
  scopeDepartmentId String?
  scopeDepartment   Department? @relation(fields: [scopeDepartmentId], references: [id], onDelete: Restrict)
  scopeLocation     String?

  startDate DateTime
  endDate   DateTime
  status    AuditCycleStatus @default(PLANNED)

  // Multitenancy
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  createdById String
  createdBy   Employee @relation("AuditCreator", fields: [createdById], references: [id], onDelete: Restrict)

  closedById String?
  closedBy   Employee? @relation("AuditCloser", fields: [closedById], references: [id], onDelete: Restrict)
  closedAt   DateTime?

  // Relations
  auditors      AuditAuditor[]
  results       AuditAssetResult[]
  discrepancies AuditDiscrepancy[]

  // Audit support
  createdByUserId String?
  createdByUser   User?           @relation("AuditCycleCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedByUserId String?
  updatedByUser   User?           @relation("AuditCycleUpdater", fields: [updatedByUserId], references: [id], onDelete: Restrict)
  deletedByUserId String?
  deletedByUser   User?           @relation("AuditCycleDeleter", fields: [deletedByUserId], references: [id], onDelete: Restrict)

  // Auditable & Soft Delete
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  isDeleted Boolean  @default(false)

  @@index([organizationId])
  @@index([status])
  @@index([isDeleted])
}

model AuditAuditor {
  id           String     @id @default(uuid())
  auditCycleId String
  auditCycle   AuditCycle @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)
  employeeId   String
  employee     Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  assignedAt   DateTime   @default(now())

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([auditCycleId, employeeId])
}

model AuditAssetResult {
  id             String               @id @default(uuid())
  auditCycleId   String
  auditCycle     AuditCycle           @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)
  assetId        String
  asset          Asset                @relation(fields: [assetId], references: [id], onDelete: Cascade)

  auditorId      String
  auditor        Employee             @relation(fields: [auditorId], references: [id], onDelete: Restrict)

  status         AuditAssetStatus     @default(PENDING)
  notes          String?
  verifiedAt     DateTime?

  discrepancy    AuditDiscrepancy?
  histories      AuditResultHistory[]

  // Multitenancy denormalization
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([auditCycleId, assetId])
  @@index([organizationId])
}

model AuditDiscrepancy {
  id                 String            @id @default(uuid())
  auditCycleId       String
  auditCycle         AuditCycle        @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)
  assetId            String
  asset              Asset             @relation(fields: [assetId], references: [id], onDelete: Cascade)
  
  auditAssetResultId String            @unique
  auditAssetResult   AuditAssetResult  @relation(fields: [auditAssetResultId], references: [id], onDelete: Cascade)

  reportedStatus     AuditAssetStatus  // Only MISSING or DAMAGED
  resolutionStatus   DiscrepancyStatus @default(OPEN)

  resolvedById       String?
  resolvedBy         Employee?         @relation(fields: [resolvedById], references: [id], onDelete: Restrict)
  resolvedAt         DateTime?
  resolutionNotes    String?

  // Multitenancy denormalization
  organizationId     String
  organization       Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  // Auditable & Soft Delete
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  deletedAt          DateTime?
  isDeleted          Boolean           @default(false)

  @@index([resolutionStatus])
  @@index([isDeleted])
  @@index([organizationId])
}

model Notification {
  id             String           @id @default(uuid())
  recipientId    String
  recipient      Employee         @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  
  title          String
  message        String
  type           NotificationType
  isRead         Boolean          @default(false)
  readAt         DateTime?
  referenceId    String?          // Holds target object uuid

  // Multitenancy denormalization
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  // Auditable & Soft Delete
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?

  @@index([recipientId, isRead])
  @@index([recipientId, createdAt])
  @@index([organizationId])
  @@index([createdAt])
}

model ActivityLog {
  id           String    @id @default(uuid())
  userId       String?
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  action       String    // e.g. "USER_LOGIN", "ASSET_ALLOCATE", "AUDIT_CLOSE"
  entityType   String    // e.g. "Asset", "AuditCycle"
  entityId     String?
  oldValue     Json?     // Stores delta updates or state values
  newValue     Json?     // Stores delta updates or state values
  severity     Severity  @default(INFO)
  module       String    // e.g. "AUTH", "ASSET", "BOOKING"

  ipAddress    String?
  userAgent    String?
  deviceId     String?

  success      Boolean   @default(true)
  errorMessage String?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@index([createdAt, severity])
}


model AssetHistory {
  id             String       @id @default(uuid())
  assetId        String
  asset          Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  status         AssetStatus
  condition      Condition
  locationId     String
  location       Location     @relation(fields: [locationId], references: [id], onDelete: Restrict)
  departmentId   String?
  department     Department?  @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  changedById    String
  changedBy      User         @relation("UserAssetHistories", fields: [changedById], references: [id], onDelete: Restrict)
  notes          String?

  // Multitenancy denormalization
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([assetId])
  @@index([createdAt])
  @@index([organizationId])
}

model ResourceBookingReminder {
  id             String          @id @default(uuid())
  bookingId      String
  booking        ResourceBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reminderTime   DateTime
  isSent         Boolean         @default(false)
  sentAt         DateTime?

  // Multitenancy denormalization
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([bookingId])
  @@index([organizationId])
}

model MaintenanceAttachment {
  id                   String             @id @default(uuid())
  maintenanceRequestId String
  maintenanceRequest   MaintenanceRequest @relation(fields: [maintenanceRequestId], references: [id], onDelete: Cascade)
  name                 String
  url                  String
  fileType             String?

  // Multitenancy denormalization
  organizationId       String
  organization         Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([maintenanceRequestId])
  @@index([organizationId])
}

model MaintenanceWorkLog {
  id                   String             @id @default(uuid())
  maintenanceRequestId String
  maintenanceRequest   MaintenanceRequest @relation(fields: [maintenanceRequestId], references: [id], onDelete: Cascade)
  technicianId         String
  technician           Employee           @relation(fields: [technicianId], references: [id], onDelete: Restrict)
  status               MaintenanceStatus
  notes                String?
  laborHours           Decimal?           @db.Decimal(5, 2)

  // Multitenancy denormalization
  organizationId       String
  organization         Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([maintenanceRequestId])
  @@index([organizationId])
}

model EmailQueue {
  id             String       @id @default(uuid())
  recipient      String
  subject        String
  body           String
  status         EmailStatus  @default(PENDING)
  retryCount     Int          @default(0)
  maxRetries     Int          @default(3)
  lastError      String?
  sentAt         DateTime?
  
  // Multitenancy denormalization
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

model NotificationPreference {
  id             String           @id @default(uuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  notificationType NotificationType
  channelEmail   Boolean          @default(true)
  channelPush    Boolean          @default(true)
  channelInApp   Boolean          @default(true)

  // Multitenancy denormalization
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([userId, notificationType])
  @@index([organizationId])
}

model AuditResultHistory {
  id                 String           @id @default(uuid())
  auditAssetResultId String
  auditAssetResult   AuditAssetResult @relation(fields: [auditAssetResultId], references: [id], onDelete: Cascade)
  oldStatus          AuditAssetStatus
  newStatus          AuditAssetStatus
  changedById        String
  changedBy          User             @relation("UserAuditResultHistories", fields: [changedById], references: [id], onDelete: Restrict)
  notes              String?

  // Multitenancy denormalization
  organizationId     String
  organization       Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([auditAssetResultId])
  @@index([organizationId])
}